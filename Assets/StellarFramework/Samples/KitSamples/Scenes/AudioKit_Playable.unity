  m_Script: {fileID: 11500000, guid: a96a7f51a8870bc43bb997d0f0d22170, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: AudioKit Playable
  summary: "\u6F14\u793A AudioKit \u521D\u59CB\u5316\u3001BGM \u5207\u6362\u30012D/3D
    \u97F3\u6548\u4E0E\u5168\u5C40\u97F3\u91CF\u63A7\u5236\u3002\u9ED8\u8BA4\u4F1A\u4F7F\u7528\u6846\u67B6\u81EA\u5E26\u7684
    DefaultAudioMixer \u548C\u81EA\u52A8\u751F\u6210\u7684\u6D4B\u8BD5\u97F3\u9891\u8D44\u6E90\u3002"
  controls: "1: \u64AD\u653E 2D UI \u97F3\u6548\n2: \u5728\u5F53\u524D\u7269\u4F53\u4F4D\u7F6E\u64AD\u653E
    3D \u7206\u70B8\u97F3\u6548\n3: \u64AD\u653E\u8DDF\u968F MovingTarget \u7684
    3D \u97F3\u6548\n4: \u5207\u6362 BattleTheme\n5: \u5207\u6362\u97F3\u6548\u9759\u97F3\n6:
    \u5FAA\u73AF\u8C03\u6574 BGM \u97F3\u91CF"
  setup: "\u573A\u666F\u5DF2\u81EA\u52A8\u7ED1\u5B9A DefaultAudioMixer\uFF0C\u5E76\u751F\u6210
    MainTheme / BattleTheme / UI_Click / Explosion / Footstep \u4E94\u4E2A\u6700\u5C0F\u97F3\u9891\u8D44\u6E90\u3002"
  expected: "\u8FDB\u5165\u573A\u666F\u540E\u4F1A\u81EA\u52A8\u64AD\u653E MainTheme\u3002\u6309\u952E\u89E6\u53D1\u65F6\u53EF\u4EE5\u542C\u5230
    BGM \u548C SFX \u53D8\u5316\uFF0C\u5E76\u5728 Console \u770B\u5230\u76F8\u5E94\u65E5\u5FD7\u3002"
  notes: "\u8FD9\u662F API \u9A8C\u8BC1\u5165\u53E3\u3002\u82E5\u4F60\u8981\u63A5\u5165\u771F\u5B9E\u9879\u76EE\uFF0C\u8BF7\u66FF\u6362\u4E3A\u9879\u76EE\u81EA\u5DF1\u7684
    Mixer\u3001\u5206\u7EC4\u53C2\u6570\u548C\u97F3\u9891\u7D20\u6750\u3002"
  anchorRight: 0
  area:
    serializedVersion: 2
    x: 12
    y: 12
    width: 470
    height: 690
