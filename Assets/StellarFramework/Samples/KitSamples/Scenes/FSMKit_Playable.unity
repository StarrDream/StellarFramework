  m_Name: 
  m_EditorClassIdentifier: 
  title: FSMKit Playable
  summary: "\u6F14\u793A MSV \u601D\u8DEF\u4E0B\u7684\u8F7B\u91CF\u72B6\u6001\u673A\uFF1AService
    \u8D1F\u8D23\u903B\u8F91\uFF0CModel \u5206\u53D1\u8868\u73B0\u8BF7\u6C42\uFF0CView
    \u9A71\u52A8 Animator\u3002"
  controls: "\u65E0\u9700\u6309\u952E\u3002\u89C2\u5BDF\u76EE\u6807\u7269\u9760\u8FD1\u4E0E\u8FDC\u79BB\u65F6\uFF0CFSMActor
    \u5728 Idle / Chase \u4E24\u4E2A\u72B6\u6001\u95F4\u5207\u6362\u3002"
  setup: "\u573A\u666F\u5DF2\u81EA\u52A8\u751F\u6210\u4E00\u4E2A\u6700\u5C0F AnimatorController\uFF0C\u5305\u542B
    Idle \u4E0E Run \u4E24\u4E2A\u72B6\u6001\uFF0C\u6EE1\u8DB3 Example_FSMKit \u7684\u72B6\u6001\u54C8\u5E0C\u8981\u6C42\u3002"
  expected: "\u5F53 EnemyTarget \u9760\u8FD1 5 \u7C73\u5185\u65F6\uFF0CFSMActor \u4F1A\u8FDB\u5165
    Chase \u5E76\u5411\u76EE\u6807\u79FB\u52A8\uFF1B\u8DDD\u79BB\u91CD\u65B0\u62C9\u5F00\u540E\u56DE\u5230
    Idle\u3002"
  notes: "\u8FD9\u4E2A Animator \u53EA\u662F\u6700\u5C0F\u9A8C\u8BC1\u8D44\u4EA7\uFF0C\u771F\u5B9E\u9879\u76EE\u8BF7\u66FF\u6362\u4E3A\u6B63\u5F0F\u89D2\u8272\u52A8\u753B\u3002"
  anchorRight: 0
  area:
    serializedVersion: 2
    x: 12
    y: 12
    width: 470
    height: 690
