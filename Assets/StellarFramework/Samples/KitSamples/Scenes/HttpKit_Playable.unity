  m_Script: {fileID: 11500000, guid: a96a7f51a8870bc43bb997d0f0d22170, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: HttpKit Playable
  summary: "\u6F14\u793A POST \u767B\u5F55\u3001Token \u6CE8\u5165\u3001GET \u8D44\u6599\u62C9\u53D6\u3001\u56FE\u7247\u4E0B\u8F7D\u3001\u5927\u6587\u4EF6\u4E0B\u8F7D\u4E0E\u8BF7\u6C42\u53D6\u6D88\u5165\u53E3\u3002"
  controls: "\u8FDB\u5165\u573A\u666F\u540E\u4F1A\u81EA\u52A8\u6267\u884C\u767B\u5F55\u6D41\u7A0B\u3002\n\u9ED8\u8BA4\u6D4B\u8BD5\u5730\u5740\u4E3A
    DummyJSON\uFF0C\u53EF\u76F4\u63A5\u9A8C\u8BC1\u3002\n\u82E5\u9700\u8981\u8C03\u7528\u8865\u4E01\u4E0B\u8F7D\uFF0C\u8BF7\u4ECE\u5916\u90E8\u811A\u672C\u6216\u6309\u94AE\u8C03\u7528
    DownloadGamePatchAsync\u3002"
  setup: "\u5F53\u524D\u573A\u666F\u9ED8\u8BA4\u4F7F\u7528 https://dummyjson.com
    \u7684 auth/login \u4E0E auth/me \u516C\u5F00\u6D4B\u8BD5\u63A5\u53E3\uFF0C\u5E76\u901A\u8FC7\u5176\u52A8\u6001\u56FE\u7247\u63A5\u53E3\u52A0\u8F7D
    banner\u3002"
  expected: "\u5F53\u63A5\u53E3\u53EF\u8FBE\u65F6\uFF0C\u5934\u50CF\u548C\u6A2A\u5E45\u4F1A\u81EA\u52A8\u586B\u5145\uFF1B\u5931\u8D25\u65F6\u4F1A\u5728
    Console \u4E2D\u8F93\u51FA\u7CBE\u786E\u9519\u8BEF\u3002"
  notes: "\u5982\u679C\u4F60\u8981\u6539\u6210\u81EA\u5DF1\u7684\u670D\u52A1\uFF0C\u53EA\u9700\u66FF\u6362
    apiBaseUrl \u4E0E\u8FD4\u56DE\u7ED3\u6784\u3002"
  anchorRight: 1
  area:
    serializedVersion: 2
    x: 12
    y: 12
    width: 470
    height: 690
